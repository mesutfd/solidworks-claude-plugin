#!/usr/bin/env bash
# SessionStart hook — injects SolidWorks plugin protocol into every session

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
PLUGIN_ROOT="$(cd "${SCRIPT_DIR}/.." && pwd)"

# Read userConfig SW_KB_HOST, fall back to the built-in default
KB_HOST="${SW_KB_HOST:-http://192.168.40.221:8100}"

escape_for_json() {
    local s="$1"
    s="${s//\\/\\\\}"
    s="${s//\"/\\\"}"
    s="${s//$'\n'/\\n}"
    s="${s//$'\r'/\\r}"
    s="${s//$'\t'/\\t}"
    printf '%s' "$s"
}

context=$(cat <<CONTEXT
You have the SolidWorks Design Plugin active.

MANDATORY RULE: Any time the user asks you to create, build, model, or design
anything in SolidWorks — including parts, assemblies, gears, shafts, housings,
or any other mechanical component — you MUST complete the full pre-start sequence
before writing any code, opening SolidWorks, or generating any geometry.

Do NOT use generic brainstorming or project planning for SolidWorks design tasks.
The knowledge base is the starting point. Always.

== LEARNER — ACTIVE FROM THE FIRST MESSAGE ==

You are continuously tracking this session for the knowledge base.
As work progresses, mentally note:
- INSTRUCTIONS: exact ordered steps you follow to build each part (corrected version only)
- MACROS: any Python/VBA/SWAPI code written — track the final working version
- KNOWN ERRORS: concrete failures with their SW API method and resolution
- LESSONS: non-obvious patterns and rules that emerge (successes AND failures)

This tracking costs nothing now and makes the session-reporter accurate at the end.
Invoke Skill(solidworks-claude-plugin:learner) to produce the structured payload.

== CRITICAL: HOW TO CALL THE KB SERVER ==

ALWAYS use the Bash tool with curl. NEVER use Fetch or WebFetch — those route
through Anthropic's cloud and cannot reach private network addresses.

Correct:   Bash tool → curl -s "http://..."   ← always quote the URL
Wrong:     Fetch(...) or WebFetch(...)

Always wrap URLs in double quotes — unquoted ? and & are treated as shell
glob/background operators in zsh and will fail.

== PRE-START SEQUENCE (run in order before any modeling) ==

Knowledge base URL: ${KB_HOST}
All APIs are public — no authentication needed.

STEP 1 — Check server
  GET ${KB_HOST}/health
  If offline: note it and continue without KB. Never block the task.

STEP 2 — Load conventions (always-apply rules)
  GET ${KB_HOST}/api/knowledge?kind=convention
  Read every body field. Treat as hard rules: metric units, ISO 2768-mK tolerance,
  6061-T6 default material, parametric modeling, named dimensions.

STEP 3 — Load design rules
  GET ${KB_HOST}/api/design-rules
  Internalize each active rule (skip deprecated:true).
  Check rules before every relevant design decision.

STEP 4 — Search task-relevant knowledge
  GET ${KB_HOST}/api/knowledge/search?q={describe what you are building}
  Read top 5-8 results. Playbooks first, then reference docs.
  Reference docs contain exact SolidWorks API signatures — do not skip them.

STEP 5 — Validate design parameters
  POST ${KB_HOST}/api/check-context
  Body: { known design params — material, process, fasteners, dimensions, wall thickness }
  React: fail=stop and fix, advisory=apply, na=ignore.

== CATALOG LOOKUP (after pre-start, before modeling) ==

STEP 6 — Find the part in the catalog
  GET ${KB_HOST}/api/categories         → find the category
  GET ${KB_HOST}/api/parts?categoryId=X → find the part in that category
  GET ${KB_HOST}/api/parts/{id}         → get full detail:
    instructions → follow as primary build guide
    macros       → run directly if complete, adapt if template
    knownErrors  → check before each SW API call, apply resolution proactively
    lessons      → apply as constraints throughout

STEP 7 — Load global errors and lessons
  GET ${KB_HOST}/api/errors
  GET ${KB_HOST}/api/lessons
  Cross-reference by swFeature before every API call.

== STANDARDS (on demand during design) ==
  GET ${KB_HOST}/api/standards/materials/{name}      — material properties
  GET ${KB_HOST}/api/standards/fits                  — shaft/hole fit deviations
  GET ${KB_HOST}/api/standards/clearance_holes/{M#}  — bolt clearance hole sizes
  GET ${KB_HOST}/api/standards/tolerances_iso2768    — tolerance values by class
  GET ${KB_HOST}/api/standards/fasteners/{M#}        — fastener geometry

== AFTER MODELING ==
  POST ${KB_HOST}/api/check-context  { final design parameters }
  Fix any new fails. Document advisories in session feedback.

== END OF EVERY SOLIDWORKS SESSION (MANDATORY) ==

After completing the model and before your final response, you MUST invoke:

  Skill(solidworks-claude-plugin:session-reporter)

This skill analyzes what was built, asks the user one yes/no consent question,
and POSTs the structured feedback to ${KB_HOST}/api/feedback.

Do NOT skip this step. Do NOT forget it. It runs after every SolidWorks session
where any modeling, design, API calls, or macro work occurred.
CONTEXT
)

escaped=$(escape_for_json "$context")

if [ -n "${CURSOR_PLUGIN_ROOT:-}" ]; then
    printf '{\n  "additional_context": "%s"\n}\n' "$escaped"
elif [ -n "${CLAUDE_PLUGIN_ROOT:-}" ] && [ -z "${COPILOT_CLI:-}" ]; then
    printf '{\n  "hookSpecificOutput": {\n    "hookEventName": "SessionStart",\n    "additionalContext": "%s"\n  }\n}\n' "$escaped"
else
    printf '{\n  "additionalContext": "%s"\n}\n' "$escaped"
fi

exit 0
