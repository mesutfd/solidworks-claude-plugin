#!/usr/bin/env bash
# SessionStart hook — injects SolidWorks plugin protocol into every session

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
PLUGIN_ROOT="$(cd "${SCRIPT_DIR}/.." && pwd)"

# Read userConfig SW_KB_HOST, fall back to the built-in default
KB_HOST="${SW_KB_HOST:-https://sw-plugin.ideep.org}"

# Generate a unique session ID for this conversation (used for feedback upsert)
SESSION_ID=$(python3 -c "import uuid; print(uuid.uuid4())" 2>/dev/null || uuidgen 2>/dev/null || cat /proc/sys/kernel/random/uuid 2>/dev/null || date +%s%N)

escape_for_json() {
    local s="$1"
    s="${s//\\/\\\\}"
    s="${s//\"/\\\"}"
    s="${s//$'\n'/\\n}"
    s="${s//$'\r'/\\r}"
    s="${s//$'\t'/\\t}"
    printf '%s' "$s"
}

context=$(cat <<CONTEXT
You have the SolidWorks Design Plugin active (KB: ${KB_HOST}).

== SESSION ID (fixed for this entire conversation) ==

SESSION_ID: ${SESSION_ID}

Include this in EVERY POST /api/feedback as "sessionId": "${SESSION_ID}".
The backend upserts on sessionId — multiple submissions update the same record.
Never omit it. Never generate a new one mid-session.

== MANDATORY PROTOCOL — RUNS ON EVERY SOLIDWORKS REQUEST ==

When the user asks you to create, build, model, or design ANYTHING in SolidWorks
(parts, assemblies, gears, shafts, housings, or any mechanical component), you
MUST invoke these skills in order before writing any code or modeling anything:

  1. Invoke Skill(solidworks-claude-plugin:pre-start)
     Loads conventions, design rules, knowledge docs, and validates parameters.

  2. Invoke Skill(solidworks-claude-plugin:kb-api)
     Looks up the specific part in the catalog (instructions, macros, errors, lessons).

Do NOT skip these. Do NOT use generic brainstorming instead. The knowledge base
is the starting point. Always.

== LEARNER — ACTIVE FROM THE FIRST MESSAGE ==

You are continuously tracking this session for the knowledge base.
As work progresses, mentally note:
- INSTRUCTIONS: exact ordered steps you follow to build each part (corrected version only)
- MACROS: every Python/VBA/SWAPI code block written — full source, final working version
- KNOWN ERRORS: concrete failures with exact SW API method and resolution
- LESSONS: non-obvious patterns and rules that emerge (successes AND failures)

Invoke Skill(solidworks-claude-plugin:learner) to produce the structured payload.

== CRITICAL: HOW TO CALL THE KB SERVER ==

ALWAYS use the Bash tool with curl. NEVER use Fetch or WebFetch.
Always wrap URLs in double quotes — unquoted ? and & fail in zsh.

== END OF EVERY SOLIDWORKS SESSION (MANDATORY) ==

After completing the model and giving the user the task result, you MUST invoke:

  Skill(solidworks-claude-plugin:session-reporter)

The skill will:
  - Check the "always send" preference (auto-POST if set)
  - Otherwise call AskUserQuestion with three options: "Yes, send now" / "Always send" / "Skip"
  - AskUserQuestion creates a proper interactive UI widget the user must click — it is
    NOT embedded in text and it blocks until the user responds
  - POST to ${KB_HOST}/api/feedback on approval

Do NOT skip this step. It runs after every session where modeling, code, or API work occurred.
Do NOT add any closing text or summary after invoking this skill — the interactive prompt is the final UI.
CONTEXT
)

escaped=$(escape_for_json "$context")

if [ -n "${CURSOR_PLUGIN_ROOT:-}" ]; then
    printf '{\n  "additional_context": "%s"\n}\n' "$escaped"
elif [ -n "${CLAUDE_PLUGIN_ROOT:-}" ] && [ -z "${COPILOT_CLI:-}" ]; then
    printf '{\n  "hookSpecificOutput": {\n    "hookEventName": "SessionStart",\n    "additionalContext": "%s"\n  }\n}\n' "$escaped"
else
    printf '{\n  "additionalContext": "%s"\n}\n' "$escaped"
fi

exit 0
