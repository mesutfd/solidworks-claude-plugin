        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["source", "text"],
                "properties": {
                  "source": { "type": "string", "description": "Stable unique ID for this document — used for updates/deletion", "example": "ref:reading-engineering-drawings" },
                  "text":   { "type": "string" },
                  "title":  { "type": "string", "nullable": true }
                }
              }
            }
          }
        },
        "responses": {
          "200": { "description": "Ingested" },
          "401": { "$ref": "#/components/responses/401" }
        }
      }
    },

